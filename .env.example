# =============================================================================
# .env.example — AudiotoNotes
# Copy to .env.local for local development.
# Add real values in Vercel → Project → Settings → Environment Variables.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Publishable (anon) key — safe to expose in the browser. RLS protects data.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Service role key — SERVER ONLY. Bypasses all RLS. Never send to browser.
# [SECRET]
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase Storage bucket names ────────────────────────────────────────────
# Must match bucket IDs in supabase/migrations/012_storage_buckets.sql
STORAGE_BUCKET_AUDIO=audio-raw
STORAGE_BUCKET_STEMS=audio-stems
STORAGE_BUCKET_MIDI=midi-files
STORAGE_BUCKET_MUSICXML=musicxml-files
STORAGE_BUCKET_EXPORTS=exports

# ── AudioShake (stem separation API) ─────────────────────────────────────────
# Cloud alternative to self-hosted Demucs. Enable with FEATURE_USE_AUDIOSHAKE=true
# [SECRET]
AUDIOSHAKE_API_KEY=ashke_xxxxxxxxxxxxxxxxxxxx
AUDIOSHAKE_API_URL=https://api.audioshake.ai

# ── Feature flags ─────────────────────────────────────────────────────────────
# Toggle features without a redeploy. Values: true | false
FEATURE_USE_AUDIOSHAKE=false
FEATURE_NOTE_EDITOR=true
FEATURE_PDF_EXPORT=false
FEATURE_BILLING=false
